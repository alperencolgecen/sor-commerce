# YOZ-Ticaret .htaccess Dosyası
# Güvenlik ve URL yönlendirme ayarları

# PHP ayarları
php_flag short_open_tag on
php_flag display_errors off
php_value error_reporting 0

# URL rewriting
RewriteEngine On

# HTTPS yönlendirmesi (production için)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# www kaldırma (opsiyonel)
# RewriteCond %{HTTP_HOST} ^www\.yoz-commerce\.com [NC]
# RewriteRule ^(.*)$ https://yoz-commerce.com/$1 [L,R=301]

# Güvenli dizinlere erişimi engelle
<FilesMatch "\.(php|log|sql|env|config)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_dir.c>
    DirectoryIndex index.php index.html
</IfModule>

# Includes ve API dizinlerini koru
<Directory "includes">
    Order allow,deny
    Deny from all
</Directory>

<Directory "api">
    Order allow,deny
    Deny from all
</Directory>

<Directory "database">
    Order allow,deny
    Deny from all
</Directory>

<Directory "vendor">
    Order allow,deny
    Deny from all
</Directory>

# Sadece belirli dosyalara erişime izin ver
<Files "api/(cart_add|cart_update|cart_remove|wishlist_toggle|search|get_cart_count|get_wishlist_count)\.php$">
    Order allow,deny
    Allow from all
</Files>

# Dosya yükleme limitleri
LimitRequestBody 10485760
LimitRequestLine 8190
LimitRequestFieldSize 8190
LimitRequestFields 100

# Gzip sıkıştırma
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-javascript "access plus 1 month"
    ExpiresByType text/html "access plus 1 week"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/x-shockwave-flash "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresDefault "access plus 2 days"
</IfModule>

# ETag ayarları
<IfModule mod_headers.c>
    FileETag MTime Size
    <IfModule mod_headers.c>
        Header unset ETag
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
    </IfModule>
</IfModule>

# XSS koruması
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://www.google.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self'"
</IfModule>

# Hata sayfaları
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php

# Hotlink koruması
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^http://(www\.)?yoz-commerce\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https://(www\.)?yoz-commerce\.com [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|svg)$ - [F,NC,L]
</IfModule>

# PHP session güvenliği
<IfModule mod_php7.c>
    php_flag session.cookie_httponly on
    php_flag session.cookie_secure off
    php_flag session.use_only_cookies on
    php_flag session.cookie_samesite lax
</IfModule>

# Upload limitleri
php_value upload_max_filesize 2M
php_value post_max_size 8M
php_value memory_limit 256M
php_value max_execution_time 30
php_value max_input_time 60

# Hata raporlama (development için)
# php_flag display_errors on
# php_value error_reporting E_ALL

# Production için
php_flag display_errors off
php_value error_reporting 0

# URL rewriting kuralları
RewriteRule ^urun/([a-zA-Z0-9-]+)$ urun.php?slug=$1 [L,QSA]
RewriteRule ^kategori/([a-zA-Z0-9-]+)$ kategori.php?slug=$1 [L,QSA]
RewriteRule ^magaza/([a-zA-Z0-9-]+)$ magaza.php?slug=$1 [L,QSA]
RewriteRule ^arama$ arama.php [L,QSA]
RewriteRule ^arama/(.*)$ arama.php?q=$1 [L,QSA]

# Admin panel yönlendirmesi
RewriteRule ^admin/?$ admin/index.php [L]
RewriteRule ^admin/([a-zA-Z0-9-]+)$ admin/$1.php [L,QSA]

# API yönlendirmesi
RewriteRule ^api/(.*)$ api/$1.php [L,QSA]

# Sitemap
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# Robots.txt
RewriteRule ^robots\.txt$ robots.txt [L]

# Favicon
RewriteRule ^favicon\.ico$ favicon.ico [L]

# Gereksiz dosya ve klasör koruması
<Files ~ "^\.">
    Order allow,deny
    Deny from all
</Files>

<Files ~ "^\.">
    Order allow,deny
    Deny from all
</Files>

<Directory ~ "^\.">
    Order allow,deny
    Deny from all
</Directory>

# Log dosyalarını koru
<FilesMatch "\.(log|txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Config dosyalarını koru
<FilesMatch "\.(ini|conf|config)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# SQL dosyalarını koru
<FilesMatch "\.(sql|dump)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Yedekleme dosyalarını koru
<FilesMatch "\.(bak|backup|old)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Geçici dosyaları koru
<FilesMatch "\.(tmp|temp)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Sistem dosyalarını koru
<FilesMatch "^\.htaccess$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Maintenance mode (bakım modu için)
# RewriteCond %{REMOTE_ADDR} !^123\.456\.789\.123$
# RewriteCond %{REQUEST_URI} !^/maintenance\.html$
# RewriteRule ^(.*)$ /maintenance.html [L]

# IP bazlı erişim kontrolü (opsiyonel)
# <RequireAll>
# Require ip 123.456.789.123
# Require ip 192.168.1.100
# </RequireAll>

# Bölgesel IP engelleme (opsiyonel)
# <RequireAll>
# Require not ip 192.168.1.0/24
# Require not ip 10.0.0.0/8
# </RequireAll>

# Kötü bot engelleme
<IfModule mod_setenvif.c>
    SetEnvIfNoCase User-Agent "^Googlebot" good_bot
    SetEnvIfNoCase User-Agent "^Bingbot" good_bot
    SetEnvIfNoCase User-Agent "^Slurp" good_bot
    SetEnvIfNoCase User-Agent "^DuckDuckBot" good_bot
    SetEnvIfNoCase User-Agent "^facebookexternalhit" bad_bot
    SetEnvIfNoCase User-Agent "^Twitterbot" good_bot
</IfModule>

<IfModule mod_rewrite.c>
    RewriteCond %{ENV:bad_bot} 1
    RewriteRule .* - [F,L]
</IfModule>

# İndexleme kontrolü (SEO için)
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Sunucu imzasını gizle
<IfModule mod_headers.c>
    ServerSignature Off
</IfModule>

# PHP hata sayfalarını gizle
<IfModule mod_php7.c>
    php_flag display_errors off
    php_value error_reporting 0
</IfModule>

# Sürüm kontrolü
AddType application/x-httpd-php .php
AddType application/x-httpd-php .phtml
