{
    "name": "yoz-commerce/ecommerce-platform",
    "description": "YOZ-Ticaret - Modern PHP E-Ticaret Platformu",
    "version": "1.0.0",
    "type": "project",
    "keywords": [
        "ecommerce",
        "php",
        "mysql",
        "responsive",
        "admin-panel",
        "shopping-cart",
        "wishlist",
        "payments"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "YOZ-Ticaret Team",
            "email": "info@yoz-ticaret.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-gd": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.8",
        "squizlabs/php_codesniffer": "^3.6",
        "friendsofphp/php-cs-fixer": "^3.13",
        "phpmd/phpmd": "^2.10",
        "phploc/phploc": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "YOZ\\": "src/",
            "App\\": "app/",
            "Admin\\": "admin/"
        },
        "files": [
            "includes/config.php",
            "includes/functions.php",
            "includes/auth.php",
            "includes/db.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@setup-env",
            "@create-dirs",
            "@set-permissions"
        ],
        "post-update-cmd": [
            "@set-permissions"
        ],
        "setup-env": [
            "cp .env.example .env"
        ],
        "create-dirs": [
            "mkdir -p logs uploads temp cache"
        ],
        "set-permissions": [
            "chmod 755 logs uploads temp cache",
            "chmod 644 logs/.gitkeep uploads/.gitkeep temp/.gitkeep cache/.gitkeep"
        ],
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html",
        "cs-check": "phpcs --standard=PSR12 src/ app/ admin/ --ignore=vendor/ --report=full",
        "cs-fix": "phpcbf --standard=PSR12 src/ app/ admin/ --ignore=vendor/",
        "phpstan": "phpstan analyse src/ app/ admin/",
        "phpmd": "phpmd src/ app/ admin/ --report=html",
        "phploc": "phploc src/ app/ admin/ --exclude=vendor/",
        "clean": "rm -rf cache/* temp/* logs/*",
        "serve": [
            "php -S localhost:8000 -t public/"
        ],
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "backup": "php database/backup.php",
        "restore": "php database/restore.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": {
        "packagist": {
            "type": "composer",
            "url": "https://packagist.org"
        }
    },
    "archive": {
        "exclude": [
            "/cache",
            "/logs",
            "/temp",
            "/uploads",
            "/vendor",
            "/node_modules",
            "/.git",
            "/.idea",
            "/.vscode"
        ]
    }
}
