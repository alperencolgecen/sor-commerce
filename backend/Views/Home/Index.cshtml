@{
    ViewData["Title"] = "SOR-Ticaret API";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SOR-Ticaret API</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: #F5F5F5;
            color: #1D1D1D;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .container { text-align: center; padding: 40px 20px; }
        .logo { width: 80px; height: 80px; border-radius: 16px; margin-bottom: 20px; }
        h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; }
        h1 span { color: #F27A1A; }
        p { color: #666; margin-bottom: 28px; font-size: 15px; }
        .links { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 8px; font-size: 14px; font-weight: 600;
            text-decoration: none; transition: all 0.2s;
        }
        .btn-primary { background: #F27A1A; color: #fff; }
        .btn-primary:hover { background: #E06E0F; }
        .btn-secondary { background: #fff; color: #1D1D1D; border: 1px solid #E8E8E8; }
        .btn-secondary:hover { border-color: #F27A1A; color: #F27A1A; }
        .endpoints { margin-top: 32px; max-width: 600px; margin-left: auto; margin-right: auto; }
        .endpoints h3 { font-size: 14px; color: #999; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
        .endpoint-list { display: flex; flex-direction: column; gap: 6px; }
        .endpoint {
            display: flex; align-items: center; gap: 10px; padding: 10px 14px;
            background: #fff; border-radius: 6px; font-size: 13px; text-align: left;
        }
        .method {
            display: inline-block; padding: 3px 8px; border-radius: 4px;
            font-size: 11px; font-weight: 700; min-width: 52px; text-align: center;
        }
        .get { background: #DCFCE7; color: #166534; }
        .post { background: #DBEAFE; color: #1E40AF; }
        .put { background: #FEF3C7; color: #92400E; }
        .del { background: #FEE2E2; color: #991B1B; }
        .endpoint code { color: #1D1D1D; }
        .endpoint span:last-child { color: #666; margin-left: auto; font-size: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <img src="https://via.placeholder.com/80x80/F27A1A/FFFFFF?text=S" alt="SOR" class="logo" />
        <h1>SOR<span>-</span>Ticaret API</h1>
        <p>ASP.NET Core 8 Web API + Swagger altyapısı hazır.</p>
        <div class="links">
            <a href="/swagger" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                Swagger UI'yi Aç
            </a>
            <a href="/swagger/v1/swagger.json" class="btn btn-secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                swagger.json
            </a>
        </div>
        <div class="endpoints">
            <h3>API Endpoints</h3>
            <div class="endpoint-list">
                <div class="endpoint"><span class="method get">GET</span> <code>/api/urun</code> <span>Tüm ürünleri listele</span></div>
                <div class="endpoint"><span class="method get">GET</span> <code>/api/urun/{id}</code> <span>ID ile ürün getir</span></div>
                <div class="endpoint"><span class="method post">POST</span> <code>/api/urun</code> <span>Yeni ürün ekle</span></div>
                <div class="endpoint"><span class="method get">GET</span> <code>/api/kategori</code> <span>Tüm kategorileri listele</span></div>
                <div class="endpoint"><span class="method post">POST</span> <code>/api/kullanici/kayit</code> <span>Kullanıcı kaydı</span></div>
                <div class="endpoint"><span class="method post">POST</span> <code>/api/kullanici/giris</code> <span>Kullanıcı girişi</span></div>
                <div class="endpoint"><span class="method post">POST</span> <code>/api/sepet/siparis</code> <span>Sipariş oluştur</span></div>
            </div>
        </div>
    </div>
</body>
</html>
